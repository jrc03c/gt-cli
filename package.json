{
  "bin": {
    "gt": "dist/index.js"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "description": "CLI for the GuidedTrack web API",
  "devDependencies": {
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^9.12.0",
    "@eslint/json": "^0.14.0",
    "@eslint/markdown": "^7.5.1",
    "@types/node": "^22.15.0",
    "eslint": "^9.39.1",
    "eslint-plugin-html": "^7.1.0",
    "globals": "^15.11.0",
    "prettier": "^3.7.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.31.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "name": "@jrc03c/gt-cli",
  "scripts": {
    "build": "tsup && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "format": "prettier --write .",
    "lint": "eslint .",
    "pub": "npm version patch --force && npm publish --access=public",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "type": "module",
  "version": "0.1.3"
}
